{
  "include": ["src/**/*.ts", "src/**/*.tsx", "worker/**/*.ts", "*.ts"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@/*": ["./src/*"],
      "next/server": ["./node_modules/vinext/dist/shims/server.d.ts"]
    }
  }
}
